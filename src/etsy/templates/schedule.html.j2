<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>{{ css }}</style>
<style>
.time-grid { width: 100%; border-collapse: collapse; }
.time-grid td { vertical-align: top; padding: 0; }
.tg-time {
    width: 0.55in;
    padding-right: 8pt;
    padding-top: 4pt;
    font-family: var(--body-font);
    font-size: 7.5pt;
    font-weight: 700;
    color: var(--muted);
    text-align: right;
    white-space: nowrap;
    border-top: 0.5pt solid var(--line);
}
.tg-write { min-height: 0.3in; border-top: 0.5pt solid var(--line); }
.tg-accent { width: 3pt; background: var(--secondary); border-top: 0.5pt solid var(--line); }
</style>
</head>
<body>
<div class="page">
    <div class="header-bar">
        <div class="theme-label">{{ section_name }}</div>
        <div class="page-title">{{ title }}</div>
        <div class="page-num">{{ page_number }} / {{ page_count }}</div>
    </div>
    <div class="accent-strip"></div>

    <div class="content-zone" style="padding-bottom: 0.08in;">
        <div class="field-row">
            <span class="field-label">Today's Focus</span>
            <div class="field-line"></div>
        </div>
        <div class="field-row">
            <span class="field-label">Date</span>
            <div class="field-line" style="max-width: 1.6in;"></div>
            <span class="field-label" style="margin-left: 0.2in;">Energy</span>
            <div class="dot-row" style="margin-left: 4pt; margin-bottom: 2pt;">
                <div class="dot-circle"></div>
                <div class="dot-circle"></div>
                <div class="dot-circle"></div>
                <div class="dot-circle"></div>
                <div class="dot-circle"></div>
            </div>
        </div>
    </div>
    <hr class="rule" style="margin: 0 0.6in 0.1in 0.6in;">

    <div class="content-zone" style="padding-top: 0; padding-bottom: 0.08in;">
        <table class="time-grid">
            {% set slots = body if body else ["5 AM","6 AM","7 AM","8 AM","9 AM","10 AM","11 AM","12 PM","1 PM","2 PM","3 PM","4 PM","5 PM","6 PM","7 PM","8 PM","9 PM","10 PM"] %}
            {% for slot in slots %}
            <tr>
                <td class="tg-time">{{ slot }}</td>
                <td class="tg-accent"></td>
                <td class="tg-write"></td>
            </tr>
            {% endfor %}
        </table>
    </div>
    <hr class="rule" style="margin: 0 0.6in 0.08in 0.6in;">

    <div class="content-zone" style="padding-top: 0;">
        <div class="card card-primary">
            <div class="card-label">Notes &amp; Follow-Ups</div>
            {% for _ in range(3) %}
            <div class="line"></div>
            {% endfor %}
        </div>
    </div>
</div>
</body>
</html>
