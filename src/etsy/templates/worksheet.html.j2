<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>{{ css }}</style>
<style>
.two-col { display: flex; gap: 0.2in; margin-bottom: 0.1in; }
.col-left  { flex: 55; }
.col-right { flex: 40; }
.time-row  { display: flex; align-items: flex-end; gap: 5pt; margin-bottom: 0.04in; }
.time-label {
    font-family: var(--body-font);
    font-size: 7.5pt;
    font-weight: 700;
    color: var(--muted);
    width: 0.45in;
    text-align: right;
    flex-shrink: 0;
    padding-bottom: 3pt;
}
</style>
</head>
<body>
<div class="page">
    <div class="header-bar">
        <div class="theme-label">{{ section_name }}</div>
        <div class="page-title">{{ title }}</div>
        <div class="page-num">{{ page_number }} / {{ page_count }}</div>
    </div>
    <div class="accent-strip"></div>

    <div class="content-zone" style="padding-bottom: 0.08in;">
        <div class="field-row">
            <span class="field-label">Date</span>
            <div class="field-line"></div>
            <span class="field-label" style="margin-left: 0.18in;">Energy</span>
            <div class="dot-row" style="margin-bottom: 2pt; margin-left: 4pt;">
                <div class="dot-circle"></div>
                <div class="dot-circle"></div>
                <div class="dot-circle"></div>
                <div class="dot-circle"></div>
                <div class="dot-circle"></div>
            </div>
        </div>
    </div>
    <hr class="rule" style="margin: 0 0.6in 0.1in 0.6in;">

    <div class="content-zone" style="padding-top: 0.05in; padding-bottom: 0.05in;">
        <div class="two-col">
            <div class="col-left">
                <div class="card-label">Top Priorities</div>
                {% for i in range(1, 6) %}
                <div class="priority-item">
                    <span class="priority-num">{{ i }}</span>
                    <div class="priority-check"></div>
                    <div class="line" style="flex: 1; margin-bottom: 0;"></div>
                </div>
                {% endfor %}
                <div style="margin-top: 0.12in;">
                    <div class="card-label">Notes</div>
                    {% for _ in range(4) %}
                    <div class="line"></div>
                    {% endfor %}
                </div>
            </div>
            <div class="col-right">
                <div class="card-label">Schedule</div>
                {% for slot in ["6 AM","7 AM","8 AM","9 AM","10 AM","11 AM","12 PM","1 PM","2 PM","3 PM","4 PM","5 PM","6 PM","7 PM","8 PM"] %}
                <div class="time-row">
                    <span class="time-label">{{ slot }}</span>
                    <div class="line" style="flex: 1; margin-bottom: 0;"></div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    <hr class="rule" style="margin: 0 0.6in 0.08in 0.6in;">

    <div class="content-zone" style="padding-top: 0; padding-bottom: 0.08in;">
        <div class="card card-secondary">
            <div class="card-label">Brain Dump</div>
            {% for _ in range(5) %}
            <div class="line"></div>
            {% endfor %}
        </div>
    </div>

    <div class="content-zone" style="padding-top: 0;">
        <div class="card-filled">
            <div class="card-label-white">Today's Win</div>
            <div class="line-white"></div>
            <div class="line-white"></div>
        </div>
    </div>
</div>
</body>
</html>
