<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>{{ css }}</style>
<style>
/* ── Cover-specific ── */
.cover-hero {
    background: var(--primary);
    height: 4.8in;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0.35in 0.65in 0.4in 0.65in;
}
.cover-kicker {
    font-family: var(--body-font);
    font-size: 7.5pt;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12pt;
}
.cover-title {
    font-family: var(--heading-font);
    font-size: 40pt;
    font-weight: 700;
    color: white;
    line-height: 1.08;
    margin-bottom: 14pt;
    max-width: 5.5in;
}
.cover-tagline {
    font-family: var(--body-font);
    font-size: 11pt;
    color: rgba(255,255,255,0.75);
    margin-bottom: 20pt;
}
.cover-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    border: 1pt solid rgba(255,255,255,0.4);
    border-radius: 20pt;
    padding: 4pt 12pt;
    font-family: var(--body-font);
    font-size: 8pt;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
}
.cover-body {
    flex: 1;
    padding: 0.28in 0.65in 0.3in 0.65in;
    background: white;
}
.cover-section-title {
    font-family: var(--body-font);
    font-size: 7.5pt;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8pt;
}
.sections-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.1in 0.2in;
}
.section-item {
    display: flex;
    align-items: flex-start;
    gap: 7pt;
    width: calc(50% - 0.1in);
}
.section-dot {
    width: 7pt;
    height: 7pt;
    border-radius: 50%;
    background: var(--secondary);
    flex-shrink: 0;
    margin-top: 2pt;
}
.section-name {
    font-family: var(--body-font);
    font-size: 9pt;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 2pt;
}
.section-desc {
    font-family: var(--body-font);
    font-size: 8pt;
    color: var(--mid);
}
.cover-info-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.15in 0.65in;
    background: var(--background);
    border-top: 0.7pt solid var(--line);
}
.cover-brand {
    font-family: var(--heading-font);
    font-size: 11pt;
    font-weight: 700;
    color: var(--dark);
}
.cover-meta {
    font-family: var(--body-font);
    font-size: 8pt;
    color: var(--muted);
    text-align: right;
}
</style>
</head>
<body>
<div class="page">
    <div class="cover-hero">
        <div class="cover-kicker">Digital Planner</div>
        <div class="cover-title">{{ title }}</div>
        <div class="cover-tagline">{{ audience }}</div>
        <div><span class="cover-badge">{{ page_count }} pages</span></div>
    </div>

    <div class="accent-strip"></div>

    <div class="cover-body">
        <div class="cover-section-title">What's Inside</div>
        <hr class="rule-accent">
        <div class="sections-grid">
            {% for s in sections %}
            <div class="section-item">
                <div class="section-dot"></div>
                <div>
                    <div class="section-name">{{ s.name }}</div>
                    <div class="section-desc">{{ s.purpose }}</div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="cover-info-bar">
        <div class="cover-brand">Betwixt &amp; Between Co.</div>
        <div class="cover-meta">{{ title }}<br>Digital Download</div>
    </div>
</div>
</body>
</html>
