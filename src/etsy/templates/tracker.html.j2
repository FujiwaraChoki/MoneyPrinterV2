<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>{{ css }}</style>
<style>
.tracker-table { width: 100%; border-collapse: collapse; }
.tracker-table th, .tracker-table td { text-align: center; vertical-align: middle; padding: 0; }
.tracker-table th {
    font-family: var(--body-font);
    font-size: 6.5pt;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.06em;
    padding-bottom: 4pt;
    border-bottom: 1pt solid var(--line);
}
.th-habit { text-align: left !important; padding-left: 4pt; width: 1.5in; }
.td-habit {
    text-align: left;
    padding: 5pt 0 5pt 4pt;
    font-family: var(--body-font);
    font-size: 8.5pt;
    color: var(--dark);
    border-bottom: 0.5pt solid var(--line);
    width: 1.5in;
}
.td-day { border-bottom: 0.5pt solid var(--line); padding: 4pt 2pt; }
.tracker-circle {
    width: 11pt;
    height: 11pt;
    border-radius: 50%;
    border: 1pt solid var(--secondary);
    display: inline-block;
}
.td-pct { border-bottom: 0.5pt solid var(--line); font-family: var(--body-font); font-size: 7.5pt; color: var(--muted); padding: 4pt 2pt; width: 0.32in; }
.th-pct { width: 0.32in; }
</style>
</head>
<body>
<div class="page">
    <div class="header-bar">
        <div class="theme-label">{{ section_name }}</div>
        <div class="page-title">{{ title }}</div>
        <div class="page-num">{{ page_number }} / {{ page_count }}</div>
    </div>
    <div class="accent-strip"></div>

    <div class="content-zone" style="padding-bottom: 0.08in;">
        <div class="field-row">
            <span class="field-label">Month</span>
            <div class="field-line" style="max-width: 1.5in;"></div>
            <span class="field-label" style="margin-left: 0.25in;">Year</span>
            <div class="field-line" style="max-width: 0.8in;"></div>
            <span class="field-label" style="margin-left: 0.25in;">Intention</span>
            <div class="field-line"></div>
        </div>
    </div>
    <hr class="rule" style="margin: 0 0.6in 0.1in 0.6in;">

    <div class="content-zone" style="padding-top: 0; padding-bottom: 0.1in;">
        {% set habits = body if body else ["Habit 1","Habit 2","Habit 3","Habit 4","Habit 5","Habit 6","Habit 7"] %}
        <table class="tracker-table">
            <thead>
                <tr>
                    <th class="th-habit">Habit</th>
                    {% for d in range(1, 32) %}<th style="width: 0.21in;">{{ d }}</th>{% endfor %}
                    <th class="th-pct">%</th>
                </tr>
            </thead>
            <tbody>
                {% for habit in habits %}
                <tr>
                    <td class="td-habit">{{ habit }}</td>
                    {% for _ in range(31) %}
                    <td class="td-day"><div class="tracker-circle"></div></td>
                    {% endfor %}
                    <td class="td-pct">&nbsp;</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <hr class="rule" style="margin: 0 0.6in 0.08in 0.6in;">

    <div class="content-zone" style="padding-top: 0;">
        <div class="card-tint">
            <div class="card-label-dark">Monthly Reflection</div>
            <div class="field-row">
                <span class="field-label">What worked?</span>
                <div class="field-line"></div>
            </div>
            <div class="field-row">
                <span class="field-label">What to improve?</span>
                <div class="field-line"></div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
