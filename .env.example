# NEVER commit .env to version control!

# Gemini API key for AI image generation (YouTube Shorts)
GEMINI_API_KEY=

# AssemblyAI API key for cloud-based subtitle transcription (optional)
ASSEMBLYAI_API_KEY=

# Email credentials for business outreach
EMAIL_USERNAME=
EMAIL_PASSWORD=
